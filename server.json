{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "whispercrawl/whispercrawler",
  "title": "WhisperCrawler MCP Server",
  "description": "Web scraping with stealth HTTP, real browsers, and Cloudflare bypass. CSS selectors supported.",
  "websiteUrl": "https://whispercrawler.io/ai/mcp-server.html",
  "repository": {
    "url": "https://github.com/WhisperCrawl/WhisperCrawler",
    "source": "github"
  },
  "icons": [
    {
      "src": "https://raw.githubusercontent.com/WhisperCrawl/WhisperCrawler/main/docs/assets/logo.png",
      "mimeType": "image/png"
    }
  ],
  "version": "0.4.2",
  "packages": [
    {
      "registryType": "pypi",
      "identifier": "whispercrawler",
