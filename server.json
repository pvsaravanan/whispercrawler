      "transport": {
        "type": "stdio"
      }
    },
    {
      "registryType": "oci",
      "identifier": "ghcr.io/whispercrawl/whispercrawler",
      "packageArguments": [
        {
          "type": "positional",
          "valueHint": "mcp",
          "isFixed": true
        }
      ],
      "transport": {
        "type": "stdio"
      }
    }
  ]
}