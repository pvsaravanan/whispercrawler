# ─────────────────────────────────────────────────────────────
# WhisperCrawler — Environment Configuration Template
# Copy this file to .env and fill in your values.
# NEVER commit your actual .env file to version control.
# ─────────────────────────────────────────────────────────────

# Provider API keys — set only the ones you use
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# Default provider and model (used when --provider flag not specified)
DEFAULT_PROVIDER=anthropic
DEFAULT_MODEL=claude-sonnet

# OpenRouter optional analytics headers
OPENROUTER_SITE_URL=https://your-project.example.com
OPENROUTER_APP_NAME=WebScrapingAgent

# Optional: HTTP/HTTPS proxy for the scraping engine
# Format: http://user:pass@host:port
PROXY_URL=

# Logging verbosity: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Maximum number of pages the agent will scrape per session
MAX_PAGES_DEFAULT=50

# Polite delay between requests (seconds, float allowed)
REQUEST_DELAY_SECONDS=1.0

# Directory where scraping outputs (JSON, CSV, DB) are stored
OUTPUT_DIR=./scraping_output
